{
  "files": {
    "includes": ["src/**/*.js"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noRedundantUseStrict": "off"
      }
    }
  }
}